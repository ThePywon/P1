# Get the current path
path=`dirname "$0"`

# Move to ./build
cd "$path/build"

# Scrape all files in directory
for entry in "../objects"/*
do
	if [[ $entry == *.o ]]
	then files="$files $entry"
  fi
done

# Link all files
g++ -pthread -o build $files -lglfw -lGLU -lGL -lXrandr -lXxf86vm -lXi -lXinerama -lX11 -lrt -ldl -fcoroutines -std=c++20
